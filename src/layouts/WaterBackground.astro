---
// src/components/WaterBackground.astro
---

<div class="water-bg" aria-hidden="true"></div>

<style>
  .water-bg {
    position: fixed;
    inset: -10%;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 80% 40% at 30% 60%, #1a0e06 0%, transparent 70%),
      radial-gradient(ellipse 60% 50% at 70% 30%, #120a04 0%, transparent 65%),
      radial-gradient(ellipse 90% 60% at 50% 80%, #1f1208 0%, transparent 60%),
      #0a0603;
    animation: water 12s ease-in-out infinite alternate;
    will-change: transform;
  }

  @keyframes water {
    0%   { transform: scale(1)    translateY(0px); }
    33%  { transform: scale(1.04) translateY(-8px); }
    66%  { transform: scale(0.99) translateY(5px); }
    100% { transform: scale(1.03) translateY(-4px); }
  }
</style>
