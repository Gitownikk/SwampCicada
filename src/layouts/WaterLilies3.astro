<style>
  .lily-corner {
    position: fixed;
    z-index: 1;
    pointer-events: none;
  }

  /* dodatkowe 20px marginesu pochłania ruch animacji bez ucinania */
  .lily-corner--tl { top: -10px;    left: -10px;  width: clamp(200px, 24vw, 320px); height: clamp(188px, 23vw, 300px); }
  .lily-corner--tr { top: -10px;    right: -10px; width: clamp(176px, 22vw, 280px); height: clamp(164px, 20vw, 260px); }
  .lily-corner--bl { bottom: -10px; left: -10px;  width: clamp(188px, 23vw, 300px); height: clamp(164px, 20vw, 260px); }
  .lily-corner--br { bottom: -10px; right: -10px; width: clamp(164px, 20vw, 260px); height: clamp(140px, 17vw, 220px); }

  .lily-corner svg {
    width: 100%;
    height: 100%;
  }

  .lily-corner--tl { animation: drift-a 9s  ease-in-out infinite alternate; }
  .lily-corner--tr { animation: drift-b 11s ease-in-out infinite alternate; }
  .lily-corner--bl { animation: drift-b 10s ease-in-out infinite alternate; }
  .lily-corner--br { animation: drift-a 12s ease-in-out infinite alternate; }

  @keyframes drift-a {
    0%   { transform: translateX(0px)  translateY(0px)  rotate(0deg); }
    40%  { transform: translateX(5px)  translateY(-3px) rotate(0.5deg); }
    100% { transform: translateX(-4px) translateY(3px)  rotate(-0.4deg); }
  }

  @keyframes drift-b {
    0%   { transform: translateX(0px)  translateY(0px)  rotate(0deg); }
    35%  { transform: translateX(-5px) translateY(4px)  rotate(-0.6deg); }
    100% { transform: translateX(4px)  translateY(-3px) rotate(0.5deg); }
  }
</style>
