---
// src/layouts/BaseLayout.astro
export interface Props {
  title: string;
  currentPage?: string;
}
const { title, currentPage = '' } = Astro.props;

const navLinks = [
  { href: '/digital-art', label: 'Digital Art' },
  { href: '/paintings',   label: 'Paintings'  },
  { href: '/sculptures',  label: 'Sculptures' },
];
const secondaryLinks = [
  { href: '/about',   label: 'About'   },
  { href: '/contact', label: 'Contact' },
];
---

<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!-- ─── PRELOAD CZCIONEK ───────────────────────────── -->
    <link rel="preload" href="/fonts/Sekuya/Sekuya-Regular.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/Mulish/Mulish-Light.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/Mulish/Mulish-Bold.woff2" as="font" type="font/woff2" crossorigin />

    <style>

      /* ─── CZCIONKI LOKALNE ────────────────────────────── */
      @font-face {
        font-family: "Sekuya";
        src: url("/fonts/Sekuya/Sekuya-Regular.ttf") format("truetype");
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "Mulish";
        src: url("/fonts/Mulish/Mulish-Light.ttf") format("truetype");
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "Mulish";
        src:url("/fonts/Mulish/Mulish-Bold.ttf") format("truetype");
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }

      /* ─── RESET ───────────────────────────────────────── */
      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      /* ─── ZMIENNE ─────────────────────────────────────── */
      :root {
        --bg:     #0a0603;
        --white:  #f0ece4;
        --dim:    #8a8070;
        --accent: #c8a84b;
      }

      /* ─── BASE ────────────────────────────────────────── */
      html, body {
        width: 100%;
        min-height: 100%;
        background: var(--bg);
        color: var(--white);
        font-family: "Mulish", sans-serif;
        overflow-x: hidden;
      }

      /* ─── NAVBAR ──────────────────────────────────────── */
      .navbar {
        display: flex;
        align-items: center;
        padding: 22px 48px;
        gap: 0;
        border-bottom: 1px solid #1c1510;
      }

    .logo {
      display: inline-block;
      height: 40px;
      width: auto;
      margin-right: 52px;
      flex-shrink: 0;
    }

    .logo img {
      height: 100%;
      width: auto;
      display: block;
    }


      .nav-primary {
        display: flex;
        align-items: center;
        gap: 40px;
        flex: 1;
      }

      .nav-secondary {
        display: flex;
        align-items: center;
        gap: 40px;
      }

      .nav-link {
        font-family: "Mulish", sans-serif;
        font-size: 0.99rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--white);
        text-decoration: none;
        transition: color 0.2s;
        position: relative;
        padding-bottom: 2px;
      }

      .nav-link:hover {
        color: #7a9a30;
      }

      .nav-link.active {
        color: var(--white);
        text-decoration: underline;
        text-underline-offset: 5px;
        text-decoration-color: #7a9a30;
        text-decoration-thickness: 1.5px;
      }

      /* ─── PAGE CONTENT ────────────────────────────────── */
      .page-content {
        padding: 48px 48px 64px;
      }
    </style>
  </head>
  <body>

    <header class="navbar">
<a href="/" class="logo" aria-label="Portfolio">
        <img src="/images/logo.svg" alt="Logo" />
</a>
      <nav class="nav-primary" aria-label="Primary navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`nav-link${currentPage === link.href ? ' active' : ''}`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <nav class="nav-secondary" aria-label="Secondary navigation">
        {secondaryLinks.map(link => (
          <a
            href={link.href}
            class={`nav-link${currentPage === link.href ? ' active' : ''}`}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </header>

    <main class="page-content">
      <slot />
    </main>

  </body>
</html>
