---
// src/layouts/BaseLayout.astro
export interface Props {
  title: string;
  currentPage?: string;
}
const { title, currentPage = '' } = Astro.props;
import logo from '../assets/images/logo2.svg?url';

const navLinks = [
  { href: '/digital-art', label: 'Digital Art' },
  { href: '/paintings',   label: 'Paintings'  },
  { href: '/sculptures',  label: 'Sculptures' },
];
const secondaryLinks = [
  { href: '/about',   label: 'About'   },
  { href: '/contact', label: 'Contact' },
];

const allLinks = [...navLinks, ...secondaryLinks];
---

<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!-- ─── PRELOAD CZCIONEK ───────────────────────────── -->
    <link rel="preload" href="/fonts/Sekuya/Sekuya-Regular.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/Mulish/Mulish-Light.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/Mulish/Mulish-Bold.woff2" as="font" type="font/woff2" crossorigin />

    <style>

      /* ─── CZCIONKI LOKALNE ────────────────────────────── */
      @font-face {
        font-family: "Sekuya";
        src: url("/fonts/Sekuya/Sekuya-Regular.ttf") format("truetype");
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "Mulish";
        src: url("/fonts/Mulish/Mulish-Light.ttf") format("truetype");
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: "Mulish";
        src:url("/fonts/Mulish/Mulish-Bold.ttf") format("truetype");
        font-weight: 700;
        font-style: normal;
        font-display: swap;
      }

      /* ─── RESET ───────────────────────────────────────── */
      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      /* ─── ZMIENNE ─────────────────────────────────────── */
      :root {
        --bg:     #0a0603;
        --white:  #f0ece4;
        --dim:    #8a8070;
        --accent: #c8a84b;
      }

      /* ─── BASE ────────────────────────────────────────── */
      html {
        background: var(--bg);
      }

      html, body {
        width: 100%;
        min-height: 100%;
        color: var(--white);
        font-family: "Mulish", sans-serif;
        overflow-x: hidden;
      }

      /* ─── NAVBAR ──────────────────────────────────────── */
      .navbar {
        display: flex;
        align-items: center;
        padding: 22px 48px;
        gap: 0;
        border-bottom: 1px solid #1c1510;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 10;
        background: #0a0603;
      }

      .logo {
        display: inline-block;
        height: 40px;
        width: auto;
        margin-right: 52px;
        flex-shrink: 0;
      }

      .logo img {
        height: 100%;
        width: auto;
        display: block;
      }

      .nav-primary {
        display: flex;
        align-items: center;
        gap: 40px;
        flex: 1;
      }

      .nav-secondary {
        display: flex;
        align-items: center;
        gap: 40px;
      }

      .nav-link {
        font-family: "Mulish", sans-serif;
        font-size: 0.99rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--white);
        text-decoration: none;
        transition: color 0.2s;
        position: relative;
        padding-bottom: 2px;
      }

      .nav-link:hover {
        color: #7a9a30;
      }

      .nav-link.active {
        color: var(--white);
        text-decoration: underline;
        text-underline-offset: 5px;
        text-decoration-color: #7a9a30;
        text-decoration-thickness: 1.5px;
      }

      /* ─── HAMBURGER ───────────────────────────────────── */
      .hamburger {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 36px;
        height: 36px;
        background: none;
        border: none;
        cursor: pointer;
        margin-left: auto;
        padding: 4px;
        flex-shrink: 0;
      }

      .hamburger span {
        display: block;
        width: 100%;
        height: 1.5px;
        background: var(--white);
        transition: transform 0.3s ease, opacity 0.3s ease;
        transform-origin: center;
      }

      /* animacja X gdy menu otwarte */
      .hamburger.open span:nth-child(1) {
        transform: translateY(6.5px) rotate(45deg);
      }
      .hamburger.open span:nth-child(2) {
        opacity: 0;
      }
      .hamburger.open span:nth-child(3) {
        transform: translateY(-6.5px) rotate(-45deg);
      }

      /* ─── MOBILE MENU ─────────────────────────────────── */
      .mobile-menu {
        display: none;
        flex-direction: column;
        gap: 0;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #0d0a07;
        border-bottom: 1px solid #1c1510;
        z-index: 50;
        padding: 8px 0;
      }

      .mobile-menu.open {
        display: flex;
      }

      .mobile-menu .nav-link {
        padding: 14px 28px;
        font-size: 0.88rem;
        letter-spacing: 0.2em;
        border-bottom: 1px solid #1a1510;
      }

      .mobile-menu .nav-link:last-child {
        border-bottom: none;
      }

      .mobile-menu .nav-divider {
        height: 1px;
        background: #2a2018;
        margin: 4px 0;
      }

      /* ─── PAGE CONTENT ────────────────────────────────── */
      .page-content {
        padding: 96px 48px 64px;
        position: relative;
        z-index: 1;
      }

      /* ─── RESPONSIVE ──────────────────────────────────── */
      @media (max-width: 960px) {
        .navbar {
          padding: 16px 20px;
        }

        .logo {
          margin-right: 0;
          height: 34px;
        }

        /* schowaj desktop nav */
        .nav-primary,
        .nav-secondary {
          display: none;
        }

        /* pokaż hamburger */
        .hamburger {
          display: flex;
        }

        .page-content {
          padding: 80px 20px 48px;
        }
      }
    </style>
  </head>
  <body>

    <header class="navbar">
      <a href="/" class="logo" aria-label="Portfolio">
        <img src={logo} alt="Logo" />
      </a>

      <!-- Desktop: primary nav -->
      <nav class="nav-primary" aria-label="Primary navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`nav-link${currentPage === link.href ? ' active' : ''}`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Desktop: secondary nav -->
      <nav class="nav-secondary" aria-label="Secondary navigation">
        {secondaryLinks.map(link => (
          <a
            href={link.href}
            class={`nav-link${currentPage === link.href ? ' active' : ''}`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile: hamburger button -->
      <button class="hamburger" id="hamburger" aria-label="Otwórz menu" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <!-- Mobile: dropdown menu -->
      <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`nav-link${currentPage === link.href ? ' active' : ''}`}
          >
            {link.label}
          </a>
        ))}
        <div class="nav-divider"></div>
        {secondaryLinks.map(link => (
          <a
            href={link.href}
            class={`nav-link${currentPage === link.href ? ' active' : ''}`}
          >
            {link.label}
          </a>
        ))}
      </div>
    </header>

    <main class="page-content">
      <slot />
    </main>

    <script>
      const btn = document.getElementById('hamburger');
      const menu = document.getElementById('mobile-menu');

      btn?.addEventListener('click', () => {
        const isOpen = menu?.classList.toggle('open');
        btn.classList.toggle('open', isOpen);
        btn.setAttribute('aria-expanded', String(isOpen));
        menu?.setAttribute('aria-hidden', String(!isOpen));
      });

      // zamknij menu po kliknięciu w link
      menu?.querySelectorAll('.nav-link').forEach(link => {
        link.addEventListener('click', () => {
          menu.classList.remove('open');
          btn?.classList.remove('open');
          btn?.setAttribute('aria-expanded', 'false');
          menu.setAttribute('aria-hidden', 'true');
        });
      });
    </script>

  </body>
</html>
