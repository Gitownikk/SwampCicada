---
// src/pages/sculptures.astro
// Zdjęcia umieszczaj w: src/assets/images/sculptures/
// Nazywaj je: 01.jpg, 02.png, 03.webp itp.

import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

const currentPage = '/sculptures';
const pageTitle   = 'Sculptures';

const PLACEHOLDER_COUNT = 6;

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/sculptures/*.{jpg,jpeg,png,webp}'
);

const images = await Promise.all(
  Object.keys(imageModules)
    .sort()
    .map(async (path) => {
      const mod = await imageModules[path]();
      return { src: mod.default, alt: path.split('/').pop()?.replace(/\.\w+$/, '') ?? '' };
    })
);
---

<BaseLayout title={pageTitle} currentPage={currentPage}>

  <style>
    /* ─── GALLERY GRID ─────────────────────────────────── */
    .gallery {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }

    .gallery-item {
      position: relative;
      aspect-ratio: 4 / 3;
      overflow: hidden;
      background: #110e0a;
      cursor: pointer;
    }

    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.4s ease, filter 0.4s ease;
      filter: brightness(0.92);
    }

    .gallery-item canvas {
      width: 100%;
      height: 100%;
      display: block;
      transition: transform 0.4s ease, filter 0.4s ease;
      filter: brightness(0.92);
    }

    .gallery-item:hover canvas {
      transform: scale(1.04);
      filter: brightness(1);
    }

    /* placeholder skeleton */
    .gallery-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: "Mulish", sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #2a2418;
      background: #0e0b08;
      border: 1px dashed #1e1a14;
    }

    /* ─── RESPONSIVE ──────────────────────────────────── */
    @media (max-width: 640px) {
      .gallery {
        grid-template-columns: 1fr;
        gap: 10px;
      }

      .gallery-item {
        aspect-ratio: 4 / 3;
      }
    }

    /* ─── LIGHTBOX ─────────────────────────────────────── */
    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(5, 3, 2, 0.92);
      z-index: 100;
      align-items: center;
      justify-content: center;
    }

    .lightbox.open {
      display: flex;
    }

    .lightbox canvas {
      max-width: 88vw;
      max-height: 88vh;
      object-fit: contain;
      box-shadow: 0 0 60px rgba(0,0,0,0.8);
    }

    .lightbox-close {
      position: absolute;
      top: 24px;
      right: 32px;
      background: none;
      border: none;
      color: #8a8070;
      font-size: 1.8rem;
      cursor: pointer;
      line-height: 1;
      transition: color 0.2s;
    }

    .lightbox-close:hover {
      color: #f0ece4;
    }

    .lightbox-prev,
    .lightbox-next {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: #8a8070;
      font-size: 2rem;
      cursor: pointer;
      padding: 16px;
      transition: color 0.2s;
      line-height: 1;
    }

    .lightbox-prev { left: 24px; }
    .lightbox-next { right: 24px; }

    .lightbox-prev:hover,
    .lightbox-next:hover {
      color: #f0ece4;
    }

    @media (max-width: 640px) {
      .lightbox-prev { left: 8px; }
      .lightbox-next { right: 8px; }
      .lightbox-close { top: 16px; right: 16px; }
    }
  </style>

  <!-- Gallery grid -->
  <div class="gallery" id="gallery">
    {images.length > 0
      ? images.map((img, i) => (
          <div class="gallery-item" data-index={i} data-src={img.src.src}>
            <canvas class="gallery-canvas" data-src={img.src.src} data-pos={img.pos} aria-label={img.alt}></canvas>
          </div>
        ))
      : Array.from({ length: PLACEHOLDER_COUNT }).map((_, i) => (
          <div class="gallery-item">
            <div class="gallery-placeholder">artwork {String(i + 1).padStart(2, '0')}</div>
          </div>
        ))
    }
  </div>

  <!-- Lightbox (aktywuje się tylko gdy są prawdziwe zdjęcia) -->
  {images.length > 0 && (
    <div class="lightbox" id="lightbox" role="dialog" aria-modal="true">
      <button class="lightbox-close" id="lb-close" aria-label="Zamknij">×</button>
      <button class="lightbox-prev" id="lb-prev" aria-label="Poprzednie">‹</button>
      <canvas id="lb-canvas" aria-label="lightbox image"></canvas>
      <button class="lightbox-next" id="lb-next" aria-label="Następne">›</button>
    </div>
  )}

  {images.length > 0 && (
    <script>
      function parsePos(pos) {
        const named = { left: 0, center: 0.5, right: 1, top: 0, bottom: 1 };
        const parts = (pos || 'center center').trim().split(/\s+/);
        function toFraction(p) {
          if (p in named) return named[p];
          if (p.endsWith('%')) return parseFloat(p) / 100;
          return 0.5;
        }
        const x = toFraction(parts[0]);
        const y = parts.length > 1 ? toFraction(parts[1]) : 0.5;
        return { x, y };
      }

      function paintCanvas(canvas, imgEl) {
        const parent = canvas.parentElement;
        const rect = parent.getBoundingClientRect();
        const w = rect.width;
        const h = rect.height;
        if (!w || !h) return;
        const dpr = devicePixelRatio || 1;
        canvas.width = Math.round(w * dpr);
        canvas.height = Math.round(h * dpr);
        const ctx = canvas.getContext('2d');
        const scale = Math.max(canvas.width / imgEl.naturalWidth, canvas.height / imgEl.naturalHeight);
        const scaledW = imgEl.naturalWidth * scale;
        const scaledH = imgEl.naturalHeight * scale;
        const overflowX = scaledW - canvas.width;
        const overflowY = scaledH - canvas.height;
        const pos = parsePos(canvas.dataset.pos);
        const x = -overflowX * pos.x;
        const y = -overflowY * pos.y;
        ctx.drawImage(imgEl, x, y, scaledW, scaledH);
      }

      function drawCanvas(canvas, src, cover) {
        const img = new window.Image();
        img.onload = () => {
          if (!cover) {
            canvas.width = img.naturalWidth;
            canvas.height = img.naturalHeight;
            canvas.getContext('2d').drawImage(img, 0, 0);
            return;
          }
          const parent = canvas.parentElement;
          if (parent.offsetWidth > 0) {
            paintCanvas(canvas, img);
          } else {
            const ro = new ResizeObserver(() => {
              if (parent.offsetWidth > 0) {
                ro.disconnect();
                paintCanvas(canvas, img);
              }
            });
            ro.observe(parent);
          }
        };
        img.src = src;
      }

      document.querySelectorAll('.gallery-canvas').forEach(c => {
        drawCanvas(c, c.dataset.src ?? '', true);
      });

      document.addEventListener('contextmenu', e => {
        if (e.target.tagName === 'CANVAS') e.preventDefault();
      });

      const items = Array.from(document.querySelectorAll('.gallery-item[data-index]'));
      const lightbox = document.getElementById('lightbox');
      document.body.appendChild(lightbox);
      const lbCanvas = document.getElementById('lb-canvas');
      let current = 0;

      const srcs = items.map(el => ({
        src: el.dataset.src ?? '',
        alt: el.dataset.alt ?? ''
      }));

      function open(index) {
        current = index;
        drawCanvas(lbCanvas, srcs[current].src, false);
        lbCanvas.setAttribute('aria-label', srcs[current].alt);
        lightbox.classList.add('open');
        document.body.style.overflow = 'hidden';
      }

      function close() {
        lightbox.classList.remove('open');
        document.body.style.overflow = '';
      }

      function prev() { open((current - 1 + srcs.length) % srcs.length); }
      function next() { open((current + 1) % srcs.length); }

      items.forEach(item => {
        item.addEventListener('click', () => open(Number(item.dataset.index)));
      });

      document.getElementById('lb-close').addEventListener('click', close);
      document.getElementById('lb-prev').addEventListener('click', prev);
      document.getElementById('lb-next').addEventListener('click', next);

      lightbox.addEventListener('click', e => { if (e.target === lightbox) close(); });

      document.addEventListener('keydown', e => {
        if (!lightbox.classList.contains('open')) return;
        if (e.key === 'Escape') close();
        if (e.key === 'ArrowLeft') prev();
        if (e.key === 'ArrowRight') next();
      });
    </script>
  )}

</BaseLayout>
