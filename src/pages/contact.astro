---
// src/pages/contact.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import cicada2 from '../assets/images/cicada2.png';
import WaterBackground from '../layouts/WaterBackground.astro';
import WaterLilies from '../layouts/WaterLilies.astro';
---

<BaseLayout title="Contact" currentPage="/contact">
  <WaterBackground />
  <WaterLilies />
  <style>
    .content-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: calc(100vh - 80px);
      gap: 60px;
      padding: 0 48px;
      position: relative;
      z-index: 1;
    }

    /* ─── LEFT BLOCK ──────────────────────────────────── */
    .left-block {
      display: flex;
      flex-direction: column;
      max-width: 480px;
      width: 100%;
    }

    .page-title-box {
      background: #0e0b08;
      padding: 22px 36px 18px;
      border-bottom: 1px solid #3a3020;
    }

    .page-title {
      font-family: "Sekuya", sans-serif;
      font-size: 2.4rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--white);
      -webkit-text-stroke: 0.5px #ffffff44;
    }

    .contact-block {
      background: #0e0b08;
      padding: 28px 36px 36px;
      display: flex;
      flex-direction: column;
      gap: 22px;
    }

    /* ─── CONTACT ROWS ────────────────────────────────── */
    .contact-item {
      display: flex;
      align-items: center;
      gap: 18px;
      text-decoration: none;
      color: var(--white);
      transition: color 0.2s;
    }

    .contact-item:hover {
      color: #7a9a30;
    }

    .contact-icon {
      flex-shrink: 0;
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .contact-icon svg {
      width: 32px;
      height: 32px;
      stroke: currentColor;
      fill: none;
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-linejoin: round;
      transition: stroke 0.2s;
    }

    .contact-label {
      font-family: "Mulish", sans-serif;
      font-size: 1rem;
      font-weight: 300;
      letter-spacing: 0.06em;
    }

    /* ─── RIGHT ILLUSTRATION ──────────────────────────── */
    .illustration {
      flex-shrink: 0;
      width: 450px;
    }

    .illustration img {
      width: 100%;
      height: auto;
      display: block;
      filter: drop-shadow(0 4px 24px rgba(0, 0, 0, 0.7));
    }

    /* ─── RESPONSIVE ──────────────────────────────────── */
    @media (max-width: 768px) {
      .content-wrap {
        flex-direction: column;
        align-items: center;
        padding: 40px 24px;
        gap: 32px;
        min-height: unset;
      }

      .left-block {
        max-width: 100%;
      }

      .page-title-box {
        padding: 18px 24px 14px;
      }

      .page-title {
        font-size: 1.8rem;
      }

      .contact-block {
        padding: 20px 24px 28px;
      }

      .contact-label {
        font-size: 0.92rem;
      }

      .illustration {
        width: 100%;
        max-width: 260px;
        order: -1; /* ilustracja nad kontaktem na mobile */
      }
    }
  </style>

  <div class="content-wrap">

    <!-- Left: title + contact links -->
    <div class="left-block">
      <div class="page-title-box">
        <h1 class="page-title">Contact</h1>
      </div>
      <div class="contact-block">

        <!-- Instagram (zakomentowane)
        <a href="https://instagram.com/wawryn" target="_blank" rel="noopener noreferrer" class="contact-item">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/>
            </svg>
          </div>
          <span class="contact-label">wawryn</span>
        </a>
        -->

        <!-- Ko-fi -->
        <a href="https://ko-fi.com/swampcicada" target="_blank" rel="noopener noreferrer" class="contact-item">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24">
              <path d="M4 5 Q3 5 3 6 L5 17 Q5.5 19 8 19.5 Q12 20.5 16 19.5 Q18.5 19 19 17 L21 6 Q21 5 20 5 Z"/>
              <path d="M19 8 Q23 8 23 11.5 Q23 15 19 15"/>
              <path d="M7 20 Q12 21.5 17 20"/>
              <path d="M11.5 15 Q8 12 8 9.5 Q8 7 10.5 7 Q12 7 12 8.5 Q12 7 13.5 7 Q16 7 16 9.5 Q16 12 12.5 15 Z"/>
            </svg>
          </div>
          <span class="contact-label">Swapm Cicada</span>
        </a>

        <!-- Email -->
        <a href="mailto:swampcicada@gmail.com" class="contact-item">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <polyline points="2,4 12,13 22,4"/>
            </svg>
          </div>
          <span class="contact-label">swampcicada@gmail.com</span>
        </a>

      </div>
    </div>

    <!-- Right: illustration -->
    <div class="illustration">
      <Image src={cicada2} alt="mascot" />
    </div>

  </div>
</BaseLayout>
