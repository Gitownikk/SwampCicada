---
// src/pages/about.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import cicada from '../assets/images/cicada.png';
import WaterBackground from '../layouts/WaterBackground.astro';
import WaterLilies from '../layouts/WaterLilies.astro';
---

<BaseLayout title="About" currentPage="/about">
  <WaterBackground />
  <WaterLilies />
  <style>
    .content-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: calc(100vh - 80px);
      gap: 60px;
      padding: 0 48px;
      position: relative;
      z-index: 1;
    }

    /* ─── LEFT BLOCK ──────────────────────────────────── */
    .left-block {
      display: flex;
      flex-direction: column;
      max-width: 480px;
      width: 100%;
    }

    .page-title-box {
      background: #0e0b08;
      padding: 22px 36px 18px;
      margin-bottom: 0;
      border-bottom: 1px solid #3a3020;
    }

    .page-title {
      font-family: "Sekuya", sans-serif;
      font-size: 2.4rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--white);
      -webkit-text-stroke: 0.5px #ffffff44;
    }

    .text-block {
      background: #0e0b08;
      padding: 28px 36px 36px;
      display: flex;
      flex-direction: column;
      gap: 18px;
    }

    .bio-text {
      font-family: "Mulish", sans-serif;
      font-size: 1rem;
      font-weight: 300;
      line-height: 1.9;
      letter-spacing: 0.06em;
      color: var(--white);
    }

    .bio-commission {
      font-family: "Mulish", sans-serif;
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: #ffffff;
      margin-top: -10px;
    }

    /* ─── EMAIL — identyczne jak w contact.astro ─────────── */
    .contact-item {
      display: flex;
      align-items: center;
      gap: 18px;
      color: var(--white);
    }

    .contact-icon {
      flex-shrink: 0;
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .contact-icon svg {
      width: 32px;
      height: 32px;
      stroke: currentColor;
      fill: none;
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-linejoin: round;
      transition: stroke 0.2s;
    }

    .contact-label {
      font-family: "Mulish", sans-serif;
      font-size: 1rem;
      font-weight: 300;
      letter-spacing: 0.06em;
    }

    /* ─── RIGHT ILLUSTRATION ──────────────────────────── */
    .illustration {
      flex-shrink: 0;
      width: 350px;
    }

    .illustration img {
      width: 100%;
      height: auto;
      display: block;
      filter: drop-shadow(0 4px 24px rgba(0,0,0,0.7));
    }

    /* ─── RESPONSIVE ──────────────────────────────────── */
    @media (max-width: 768px) {
      .content-wrap {
        flex-direction: column;
        align-items: center;
        padding: 40px 24px;
        gap: 32px;
        min-height: unset;
      }

      .left-block {
        max-width: 100%;
      }

      .page-title-box {
        padding: 18px 24px 14px;
      }

      .page-title {
        font-size: 1.8rem;
      }

      .text-block {
        padding: 20px 24px 28px;
      }

      .illustration {
        width: 100%;
        max-width: 280px;
        order: -1; /* ilustracja nad tekstem na mobile */
      }
    }
  </style>

  <div class="content-wrap">

    <!-- Left: title + bio -->
    <div class="left-block">
      <div class="page-title-box">
        <h1 class="page-title">About</h1>
      </div>
      <div class="text-block">
        <p class="bio-text">
          I'm a visual artist and cognitive science student working across
          painting, digital art, and sculpture. My work spans the full spectrum:
          from the delicate to the grotesque, from fantasy realms to our own natural world.
          Insects, nature, the beautiful and the unsettling - I don't choose sides. <br>
          Studying how the mind perceives and constructs reality has only deepened my
          fascination with imagery - how visual experience shapes thought in ways we rarely notice.
<!-- opcja 1: how we perceive far less than we think we do, and yet feel certain of what we see. -->
<!-- opcja 2: how visual experience shapes thought in ways we rarely notice. -->
<!-- opcja 3: how the same image can feel entirely different depending on the mind behind the eyes. -->
        </p>
        <b class="bio-commission">Available for commissions and freelance work</b>
        <div class="contact-item">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <polyline points="2,4 12,13 22,4"/>
            </svg>
          </div>
          <span class="contact-label">swapmcicada@gmail.com</span>
        </div>
      </div>
    </div>

    <!-- Right: illustration -->
    <div class="illustration">
      <Image src={cicada} alt="mascot" />
    </div>

  </div>
</BaseLayout>
