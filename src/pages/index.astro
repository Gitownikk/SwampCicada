---
// src/pages/index.astro
import logo from '../assets/images/logo.svg?url';
import { Image } from 'astro:assets';
import WaterBackground from '../layouts/WaterBackground.astro';
import WaterLilies from '../layouts/WaterLilies.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/carousel/*.{jpg,jpeg,png,webp}'
);

// ─── USTAW KADROWANIE DLA WYBRANYCH SLAJDÓW ───────────────
// pos – object-position (np. 'center top', 'center 20%')
// fit – 'cover' (domyślnie, przycina) | 'contain' (całość widoczna)
type SlideConfig = { pos?: string; fit?: string };
const positions: Record<string, SlideConfig> = {
  '01.png': { pos: 'top 50%'},
  '03.png': { pos: 'center 20%' },
  '04.png': { pos: 'center 20%' },
};
// ──────────────────────────────────────────────────────────

const slides = await Promise.all(
  Object.keys(imageModules)
    .sort()
    .map(async (path) => {
      const mod = await imageModules[path]();
      const filename = path.split('/').pop() ?? '';
      const cfg = positions[filename] ?? {};
      return {
        src: mod.default,
        pos: cfg.pos ?? 'center center',
        fit: cfg.fit ?? 'cover',
      };
    })
);
---

<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Swamp Cicada</title>
    <style>
      /* @font-face injected via script below using BASE_URL */

      /* ─── RESET ───────────────────────────────────────── */
      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      /* ─── ZMIENNE ─────────────────────────────────────── */
      :root {
        --bg:     #0a0603;
        --white:  #f0ece4;
        --dim:    #8a8070;
        --accent: #c8a84b;
      }

      /* ─── BASE ────────────────────────────────────────── */
      html {
        background: var(--bg);
      }

      html, body {
        width: 100%;
        height: 100%;
        color: var(--white);
        font-family: "Mulish", sans-serif;
        overflow-x: hidden;
      }

      /* ─── LAYOUT ──────────────────────────────────────── */

      .page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        z-index: 1;
      }

      .inner {
        display: flex;
        align-items: center;
        gap: 40px;
        padding: 60px 40px;
        max-width: 1000px;
        width: 100%;
      }

      /* ─── LEFT PANEL ──────────────────────────────────── */
      .left {
        display: flex;
        flex-direction: column;
        min-width: 200px;
        flex-shrink: 0;
      }

      .logo {
          align-self: center;
          display: inline-block;
          height: 80px;
          width: auto;
          margin-bottom: 36px;
      }

      .logo img {
        height: 100%;
        width: auto;
        display: block;
      }

      .nav-group {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-bottom: 36px;
      }

      .nav-link {
        font-family: "Mulish", sans-serif;
        font-size: 0.99rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--white);
        text-decoration: none;
        transition: color 0.2s;
        line-height: 2;
      }

      .nav-link:hover {
        color: #7a9a30;
      }

      /* ─── RIGHT PANEL ─────────────────────────────────── */
      .right {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
      }

      /* ─── SLIDESHOW ───────────────────────────────────── */
      .slideshow {
        position: relative;
        width: 100%;
        max-width: 580px;
        aspect-ratio: 16 / 9;
        background: #1a1410;
        border: 1px solid #2a2018;
        overflow: hidden;
      }

      .slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 0.8s ease;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .slide.active {
        opacity: 1;
      }

      .slide canvas {
        width: 100%;
        height: 100%;
        display: block;
      }

      .slide-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Mulish", sans-serif;
        font-size: 0.75rem;
        letter-spacing: 0.2em;
        color: #3a3028;
        background: #110e0a;
        text-transform: uppercase;
      }

      /* ─── DOTS ────────────────────────────────────────── */
      .slide-dots {
        display: flex;
        gap: 6px;
        position: absolute;
        bottom: 10px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 3;
      }

      .dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: rgba(240, 236, 228, 0.3);
        cursor: pointer;
        transition: background 0.3s;
        border: none;
        padding: 0;
      }

      .dot.active {
        background: var(--white);
      }

      /* ─── SOCIAL ROW ──────────────────────────────────── */
      .social-row {
        display: flex;
        align-items: center;
        gap: 28px;
        padding-top: 4px;
      }

      .social-item {
        display: flex;
        align-items: center;
        gap: 9px;
        text-decoration: none;
        color: var(--dim);
        transition: color 0.2s;
        font-family: "Mulish", sans-serif;
        font-size: 0.99rem;
        letter-spacing: 0.04em;
        font-weight: 300;
      }

      .social-item:hover {
        color: var(--white);
      }

      .social-item svg {
        flex-shrink: 0;
        opacity: 0.7;
        transition: opacity 0.2s;
      }

      .social-item:hover svg {
        opacity: 1;
      }

      /* ─── RESPONSIVE ──────────────────────────────────── */
      @media (max-width: 640px) {
        .inner {
          flex-direction: column;
          align-items: center;
          padding: 40px 24px;
          gap: 32px;
        }

        .left {
          width: 100%;
          min-width: unset;
          align-items: center;
        }

        .logo {
          height: 64px;
          margin-bottom: 24px;
        }

        .nav-group {
          align-items: center;
          margin-bottom: 20px;
        }

        .nav-link {
          font-size: 0.9rem;
        }

        .right {
          width: 100%;
          align-items: center;
        }

        .slideshow {
          max-width: 100%;
        }

        .social-row {
          flex-wrap: wrap;
          justify-content: center;
          gap: 16px;
        }

        .social-item {
          font-size: 0.88rem;
        }
      }
    </style>
  </head>
  <body>
    <WaterBackground />
    <WaterLilies />
    <div class="page">
      <div class="inner">

        <!-- Left: nav -->
        <nav class="left" aria-label="Main navigation">
          <a href={base} class="logo" aria-label="Logo">
            <img src={logo} alt="Logo" />
          </a>

          <div class="nav-group">
            <a href={`${base}digital-art`} class="nav-link">Digital Art</a>
            <a href={`${base}paintings`} class="nav-link">Paintings</a>
            <a href={`${base}sculptures`} class="nav-link">Sculptures</a>
          </div>

          <div class="nav-group">
            <a href={`${base}about`} class="nav-link">About</a>
            <a href={`${base}contact`} class="nav-link">Contact</a>
          </div>
        </nav>

        <!-- Right: slideshow + social -->
        <div class="right">
          <div class="slideshow" id="slideshow">
            {slides.length > 0
              ? slides.map((img, i) => (
                  <div class={`slide${i === 0 ? ' active' : ''}`}>
                    <canvas class="slide-canvas" data-src={img.src.src} data-fit={img.fit} data-pos={img.pos}></canvas>
                  </div>
                ))
              : [1,2,3,4].map((n) => (
                  <div class={`slide${n === 1 ? ' active' : ''}`}>
                    <div class="slide-placeholder">artwork {String(n).padStart(2,'0')}</div>
                  </div>
                ))
            }

            <div class="slide-dots" id="dots"></div>
          </div>

          <!-- Social -->
          <div class="social-row">
            <!-- Instagram (zakomentowane)
            <a
              href="https://instagram.com/wawryn"
              target="_blank"
              rel="noopener noreferrer"
              class="social-item"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/>
              </svg>
              wawryn
            </a>
            -->

            <a href="mailto:swampcicada@gmail.com" class="social-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <polyline points="2,4 12,13 22,4"/>
              </svg>
              swampcicada@gmail.com
            </a>
          </div>
        </div>

      </div>
    </div>

    <script>
      // Inject @font-face with correct base URL for GitHub Pages
      const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
      const style = document.createElement('style');
      style.textContent = `
        @font-face {
          font-family: "Sekuya";
          src: url("${base}fonts/Sekuya/Sekuya-Regular.ttf") format("truetype");
          font-weight: normal;
          font-style: normal;
          font-display: swap;
        }
        @font-face {
          font-family: "Mulish";
          src: url("${base}fonts/Mulish/Mulish-Light.ttf") format("truetype");
          font-weight: 400;
          font-style: normal;
          font-display: swap;
        }
        @font-face {
          font-family: "Mulish";
          src: url("${base}fonts/Mulish/Mulish-Bold.ttf") format("truetype");
          font-weight: 700;
          font-style: normal;
          font-display: swap;
        }
      `;
      document.head.prepend(style);
    </script>

    <script>
      // ── Rysuj slajdy jako canvas
      function parsePos(pos) {
        const named = { left: 0, center: 0.5, right: 1, top: 0, bottom: 1 };
        const parts = (pos || 'center center').trim().split(/\s+/);
        function toFraction(p) {
          if (p in named) return named[p];
          if (p.endsWith('%')) return parseFloat(p) / 100;
          return 0.5;
        }
        const x = toFraction(parts[0]);
        const y = parts.length > 1 ? toFraction(parts[1]) : 0.5;
        return { x, y };
      }

      function drawSlideCanvas(canvas) {
        const src = canvas.dataset.src;
        const fit = canvas.dataset.fit || 'cover';
        const img = new window.Image();
        img.onload = () => {
          const parent = canvas.parentElement;
          const rect = parent.getBoundingClientRect();
          const w = rect.width || parent.offsetWidth || 600;
          const h = rect.height || parent.offsetHeight || 400;
          const dpr = devicePixelRatio || 1;
          canvas.width = Math.round(w * dpr);
          canvas.height = Math.round(h * dpr);
          const ctx = canvas.getContext('2d');
          if (fit === 'contain') {
            const scale = Math.min(canvas.width / img.naturalWidth, canvas.height / img.naturalHeight);
            const x = (canvas.width - img.naturalWidth * scale) / 2;
            const y = (canvas.height - img.naturalHeight * scale) / 2;
            ctx.drawImage(img, x, y, img.naturalWidth * scale, img.naturalHeight * scale);
          } else {
            const scale = Math.max(canvas.width / img.naturalWidth, canvas.height / img.naturalHeight);
            const scaledW = img.naturalWidth * scale;
            const scaledH = img.naturalHeight * scale;
            const overflowX = scaledW - canvas.width;
            const overflowY = scaledH - canvas.height;
            const pos = parsePos(canvas.dataset.pos);
            const x = -overflowX * pos.x;
            const y = -overflowY * pos.y;
            ctx.drawImage(img, x, y, scaledW, scaledH);
          }
        };
        img.src = src;
      }

      document.querySelectorAll('.slide-canvas').forEach(c => drawSlideCanvas(c));

      document.addEventListener('contextmenu', e => {
        if (e.target.tagName === 'CANVAS') e.preventDefault();
      });

      // ── Karuzela
      const slides = document.querySelectorAll('.slide');
      const dotsContainer = document.getElementById('dots');
      let current = 0;

      slides.forEach((_, i) => {
        const btn = document.createElement('button');
        btn.className = 'dot' + (i === 0 ? ' active' : '');
        btn.setAttribute('aria-label', `Slide ${i + 1}`);
        btn.addEventListener('click', () => goTo(i));
        dotsContainer.appendChild(btn);
      });

      const dots = dotsContainer.querySelectorAll('.dot');

      function goTo(index) {
        slides[current].classList.remove('active');
        dots[current].classList.remove('active');
        current = (index + slides.length) % slides.length;
        slides[current].classList.add('active');
        dots[current].classList.add('active');
        dotsContainer.classList.add('dots--visible');
      }

      const INTRO_PAUSE = 3000;
      let timer = setTimeout(() => {
        goTo(1);
        timer = setInterval(() => goTo(current + 1), 3500);
      }, INTRO_PAUSE);

      const slideshow = document.getElementById('slideshow');
      slideshow.addEventListener('mouseenter', () => { clearTimeout(timer); clearInterval(timer); });
      slideshow.addEventListener('mouseleave', () => {
        timer = setInterval(() => goTo(current + 1), 3500);
      });
    </script>
  </body>
</html>
